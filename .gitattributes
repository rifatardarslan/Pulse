# Normalize line endings to LF on commit, checkout as-is
* text=auto eol=lf

# Force LF for these file types
*.py    text eol=lf
*.toml  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.sh    text eol=lf
*.env   text eol=lf

# Binary files — no line ending conversion
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
*.gz    binary
*.zip   binary
