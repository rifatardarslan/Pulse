# ─────────────────────────────────────────────────────────────
# Pulse — Environment Variables Template
# Bu dosyayı .env olarak kopyalayın: cp .env.example .env
# ─────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=pulse
POSTGRES_PASSWORD=pulse123
POSTGRES_DB=pulse
DATABASE_URL=postgresql+asyncpg://pulse:pulse123@db:5432/pulse

# Redis & Celery
REDIS_URL=redis://redis:6379/0

# AI — Ollama (yerel) veya OpenAI uyumlu herhangi bir servis
# host.docker.internal: Docker container içinden host'taki Ollama'ya erişim
OLLAMA_BASE_URL=http://host.docker.internal:11434
AI_API_KEY=ollama
AI_MODEL=llama3

# GPT-4o kullanmak için:
# OLLAMA_BASE_URL=https://api.openai.com
# AI_API_KEY=sk-...
# AI_MODEL=gpt-4o
